# khaos-id environment — copy to .env.local for local development.
# All values below are the defaults emitted by `supabase start` on a fresh
# project. They are NOT secrets in any meaningful sense (the stack is bound to
# 127.0.0.1) but the file is still gitignored so individual installs stay clean.
#
# Production substrate is hosted Supabase: project "khaos-id" (uwgykeijsejiitwmvzrl)
# in region eu-west-1. See docs/adr/0003-hosted-supabase-substrate.md.
# Production values are managed in Vercel — pull with `vercel env pull` if needed.
# See docs/deployment.md.

# Public Supabase URL (server-rendered, anon-key-fronted).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlLWRlbW8iLCJpYXQiOjE2NDE3NjkyMDAsImV4cCI6MTc5OTUzNTYwMH0.dc_X5iR_VP_qT0zsiyj_I_OZ2T9FtRU2BBNWN8Bu4GE

# Server-only. Never exposed to the browser. Needed for admin / RLS-bypass paths.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoic3VwYWJhc2UtZGVtbyIsImlhdCI6MTY0MTc2OTIwMCwiZXhwIjoxNzk5NTM1NjAwfQ.DaYlNEoUrrEn2Ig7tqibS-PHK5vgusbcbo7X36XVt4Q

# JWKS endpoint exposed by local Supabase Auth. Public; signed-key half only.
SUPABASE_JWKS_URL=http://127.0.0.1:54321/auth/v1/.well-known/jwks.json

# Expected audience of access tokens (Supabase Auth default).
SUPABASE_JWT_AUDIENCE=authenticated
